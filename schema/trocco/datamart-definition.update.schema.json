{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Growth-Management/trocco-mcp-tools/schema/trocco/datamart-definition.update.schema.json",
  "title": "update_datamart_definition",
  "description": "Guarded MCP input schema for PATCH /api/datamart_definitions/{datamart_definition_id}. BigQuery mutable fields are intentionally allowlisted for audit-safe operation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["datamart_definition_id", "patch", "confirm", "change_reason"],
  "properties": {
    "datamart_definition_id": {
      "type": "integer",
      "minimum": 1
    },
    "patch": {
      "type": "object",
      "description": "Allowed BigQuery datamart option fields. The MCP implementation should wrap these under datamart_bigquery_option when sending the TROCCO request.",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "query": { "type": "string" },
        "destination_dataset": { "type": "string" },
        "destination_table": { "type": "string" },
        "write_disposition": {
          "type": "string",
          "enum": ["append", "truncate", "incremental", "scd_type_2"]
        },
        "schema_evolution_mode": {
          "type": "string",
          "enum": ["detect_only", "auto_add_column"]
        },
        "incremental_column": { "type": ["string", "null"] },
        "merge_keys": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "on_matched_action": {
          "type": ["string", "null"],
          "enum": ["upsert", "skip", null]
        },
        "lookback_period_column": { "type": ["string", "null"] },
        "lookback_period_column_type": {
          "type": ["string", "null"],
          "enum": ["TIMESTAMP", "DATETIME", "DATE", null]
        },
        "lookback_period_timezone": { "type": ["string", "null"] },
        "lookback_period_from": { "type": ["integer", "null"] },
        "lookback_period_to": { "type": ["integer", "null"] },
        "lookback_period_unit": {
          "type": ["string", "null"],
          "enum": ["days", "hours", null]
        },
        "before_load": { "type": ["string", "null"] },
        "partitioning": {
          "type": ["string", "null"],
          "enum": ["ingestion_time", "time_unit_column", null]
        },
        "partitioning_time": {
          "type": ["string", "null"],
          "enum": ["DAY", "HOUR", "MONTH", "YEAR", null]
        },
        "partitioning_field": { "type": ["string", "null"] },
        "clustering_fields": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 0,
          "maxItems": 4
        }
      }
    },
    "expected_current": {
      "type": "object",
      "description": "Optional guard values checked before update when implemented.",
      "additionalProperties": true
    },
    "confirm": {
      "type": "boolean",
      "const": true
    },
    "change_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
