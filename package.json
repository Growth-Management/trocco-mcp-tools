{
  "name": "trocco-mcp-tools",
  "version": "0.1.1",
  "description": "Read-only MCP tools for TROCCO workflow and BigQuery datamart auditing.",
  "type": "module",
  "private": true,
  "bin": {
    "trocco-mcp-tools": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "smoke:http": "node scripts/smoke-http.mjs",
    "smoke:actions": "node scripts/smoke-datamart-actions.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "express": "^4.19.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
